# ── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database (Supabase cloud OR local PostgREST) ──────────────────────────────
# Cloud:  SUPABASE_URL=https://your-project.supabase.co
# Local:  SUPABASE_URL=http://postgrest-proxy  (Docker dev setup)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── RAG / Chunking tunables ───────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
BATCH_SIZE=10

# ── Storage bucket names ──────────────────────────────────────────────────────
BUCKET_POLICIES=hr_policies
BUCKET_DOCS=hr-docs
BUCKET_TEMPLATES=hr-templates
BUCKET_REPORTS=hr-reports

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production
